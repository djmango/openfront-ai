{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "resources/*": ["./openfront/resources/*"],
      "src/*": ["./openfront/src/*"]
    },
    "sourceMap": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "strictNullChecks": true,
    "useDefineForClassFields": false,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["datagen/**/*", "openfront/src/**/*"]
}
