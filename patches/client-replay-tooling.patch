diff --git a/src/client/RlDebugOverlay.ts b/src/client/RlDebugOverlay.ts
new file mode 100644
index 00000000..bc3d31a0
--- /dev/null
+++ b/src/client/RlDebugOverlay.ts
@@ -0,0 +1,292 @@
+/**
+ * RL replay tooling: live model-debug panel.
+ *
+ * Fetches per-decision policy debug data (chosen action, action
+ * probabilities, value estimate) for the current game and renders a small
+ * draggable panel that follows the sim via window.__replayTick (set in
+ * ClientGameRunner). When the decision includes a tile target, draws a red
+ * X on the map at that world coordinate.
+ */
+
+interface RlDebugEntry {
+  tick: number;
+  desc: string;
+  action: string;
+  tiles: number;
+  troops: number;
+  value?: number;
+  probs?: number[];
+  /** World tile x (optional; preferred over parsing desc). */
+  tile_x?: number;
+  /** World tile y (optional; preferred over parsing desc). */
+  tile_y?: number;
+}
+
+interface RlDebugPayload {
+  actions: string[];
+  log: RlDebugEntry[];
+  live?: boolean;
+}
+
+/** Region size used by the policy tile head (rl.obs.REGION). */
+const REGION = 8;
+
+let initialized = false;
+
+function esc(s: string): string {
+  return s.replace(/&/g, "&amp;").replace(/</g, "&lt;");
+}
+
+/** Resolve world (x, y) from explicit fields or legacy `@(gx,gy)` in desc. */
+function entryTile(e: RlDebugEntry): { x: number; y: number } | null {
+  if (
+    typeof e.tile_x === "number" &&
+    typeof e.tile_y === "number" &&
+    Number.isFinite(e.tile_x) &&
+    Number.isFinite(e.tile_y)
+  ) {
+    return { x: e.tile_x, y: e.tile_y };
+  }
+  const m = /@\((-?\d+),(-?\d+)\)/.exec(e.desc);
+  if (!m) return null;
+  const gx = Number(m[1]);
+  const gy = Number(m[2]);
+  return {
+    x: gx * REGION + Math.floor(REGION / 2),
+    y: gy * REGION + Math.floor(REGION / 2),
+  };
+}
+
+function makeDraggable(el: HTMLElement): void {
+  const key = "rlDebugOverlayPos";
+  try {
+    const saved = localStorage.getItem(key);
+    if (saved) {
+      const pos = JSON.parse(saved) as { left: number; top: number };
+      el.style.left = `${pos.left}px`;
+      el.style.top = `${pos.top}px`;
+    }
+  } catch {
+    // ignore bad saved position
+  }
+
+  let dragging = false;
+  let offsetX = 0;
+  let offsetY = 0;
+
+  el.addEventListener("mousedown", (ev) => {
+    dragging = true;
+    offsetX = ev.clientX - el.offsetLeft;
+    offsetY = ev.clientY - el.offsetTop;
+    ev.preventDefault();
+  });
+
+  window.addEventListener("mousemove", (ev) => {
+    if (!dragging) return;
+    const left = Math.max(20, Math.min(window.innerWidth - el.offsetWidth, ev.clientX - offsetX));
+    const top = Math.max(0, Math.min(window.innerHeight - 40, ev.clientY - offsetY));
+    el.style.left = `${left}px`;
+    el.style.top = `${top}px`;
+  });
+
+  window.addEventListener("mouseup", () => {
+    if (!dragging) return;
+    dragging = false;
+    try {
+      localStorage.setItem(
+        key,
+        JSON.stringify({ left: el.offsetLeft, top: el.offsetTop }),
+      );
+    } catch {
+      // localStorage unavailable
+    }
+  });
+}
+
+function makeTargetMarker(): HTMLElement {
+  const marker = document.createElement("div");
+  marker.id = "rl-action-target";
+  marker.setAttribute("aria-hidden", "true");
+  marker.style.cssText =
+    "position:fixed;z-index:10004;pointer-events:none;display:none;" +
+    "width:28px;height:28px;margin-left:-14px;margin-top:-14px;" +
+    "color:#e02020;font:700 28px/28px ui-monospace,monospace;" +
+    "text-align:center;text-shadow:0 0 2px #000,0 0 4px #000,1px 1px 0 #000,-1px -1px 0 #000;" +
+    "transform:translateZ(0)";
+  marker.textContent = "✕";
+  document.body.appendChild(marker);
+  return marker;
+}
+
+function updateTargetMarker(
+  marker: HTMLElement,
+  e: RlDebugEntry | null,
+): void {
+  if (!e || e.action === "noop") {
+    marker.style.display = "none";
+    return;
+  }
+  const tile = entryTile(e);
+  if (!tile) {
+    marker.style.display = "none";
+    return;
+  }
+  const w2s = (
+    window as {
+      __worldToScreen?: (x: number, y: number) => { x: number; y: number };
+    }
+  ).__worldToScreen;
+  if (!w2s) {
+    marker.style.display = "none";
+    return;
+  }
+  try {
+    const screen = w2s(tile.x + 0.5, tile.y + 0.5);
+    marker.style.left = `${screen.x}px`;
+    marker.style.top = `${screen.y}px`;
+    marker.style.display = "block";
+  } catch {
+    marker.style.display = "none";
+  }
+}
+
+export function initRlDebugOverlay(gameID: string): void {
+  if (initialized) return;
+  initialized = true;
+
+  let hosts: string[];
+  try {
+    if (localStorage.getItem("rlDebugOverlay") === "0") return;
+    const local = ["localhost", "127.0.0.1"].includes(window.location.hostname);
+    hosts = [
+      localStorage.getItem("rlDebugHost"),
+      `${location.origin}/play`,
+      localStorage.getItem("apiHost"),
+      `${location.origin}/archive`,
+      local ? "http://localhost:8988" : null,
+    ].filter((h): h is string => !!h);
+    hosts = [...new Set(hosts.map((h) => h.replace(/\/$/, "")))];
+  } catch {
+    return;
+  }
+  if (hosts.length === 0) return;
+
+  const el = document.createElement("div");
+  el.style.cssText =
+    "position:fixed;left:20px;top:120px;width:420px;z-index:10005;" +
+    "background:rgba(12,14,22,.92);color:#d2d6e0;" +
+    "font:14px/1.45 ui-monospace,monospace;" +
+    "padding:12px 14px;border-radius:10px;pointer-events:auto;" +
+    "border:1px solid rgba(255,255,255,.12);cursor:move;user-select:none;" +
+    "box-shadow:0 8px 28px rgba(0,0,0,.45)";
+  el.innerHTML =
+    '<b style="color:#fff;font-size:15px">MODEL</b><br>connecting to decision feed…';
+  document.body.appendChild(el);
+  makeDraggable(el);
+  const marker = makeTargetMarker();
+
+  let actions: string[] = [];
+  let log: RlDebugEntry[] = [];
+  let idx = 0;
+  let feedUrl: string | null = null;
+  const recent: string[] = [];
+  const urls = hosts.map((h) => `${h}/debug/${gameID}`);
+
+  async function tryConnect(): Promise<boolean> {
+    for (const url of urls) {
+      try {
+        const resp = await fetch(url);
+        if (!resp.ok) continue;
+        const data = (await resp.json()) as RlDebugPayload;
+        if (!Array.isArray(data.log)) continue;
+        actions = data.actions ?? [];
+        log = data.log;
+        feedUrl = url;
+        idx = 0;
+        return true;
+      } catch {
+        // try next host
+      }
+    }
+    return false;
+  }
+
+  void (async () => {
+    // Live webbot feeds and archive sidecars can appear after the spectator
+    // tab joins - keep retrying instead of giving up after three attempts.
+    while (!(await tryConnect())) {
+      el.innerHTML =
+        '<b style="color:#fff;font-size:15px">MODEL</b><br>waiting for decision feed…';
+      await new Promise((r) => setTimeout(r, 2000));
+    }
+  })();
+
+  setInterval(() => {
+    if (!feedUrl) return;
+    void fetch(feedUrl)
+      .then((r) => (r.ok ? r.json() : null))
+      .then((d: RlDebugPayload | null) => {
+        if (!d || !Array.isArray(d.log)) return;
+        if (
+          log.length &&
+          d.log.length &&
+          (d.log[0]?.tick !== log[0]?.tick || d.log.length < idx)
+        ) {
+          idx = 0;
+        }
+        log = d.log;
+        if (d.actions?.length) actions = d.actions;
+      })
+      .catch(() => {});
+  }, 2000);
+
+  setInterval(() => {
+    const t = (window as { __replayTick?: number }).__replayTick;
+    if (t === undefined) return;
+    while (idx < log.length && log[idx].tick <= t) {
+      const e = log[idx++];
+      if (e.action !== "noop") {
+        recent.push(`t${e.tick} ${e.desc}`);
+        if (recent.length > 8) recent.shift();
+      }
+    }
+    const e = idx > 0 ? log[idx - 1] : null;
+    updateTargetMarker(marker, e);
+    let html =
+      '<b style="color:#fff;font-size:15px">MODEL</b> ' +
+      `<span style="color:#787e8c;font-size:13px">tick ${t}</span><br>`;
+    if (!feedUrl) {
+      el.innerHTML = html + "waiting for decision feed…";
+      return;
+    }
+    if (!e) {
+      el.innerHTML = html + "waiting for decisions...";
+      return;
+    }
+    html += `tiles ${e.tiles.toLocaleString()}  troops ${e.troops.toLocaleString()}`;
+    if (e.value !== undefined) html += `  v ${e.value >= 0 ? "+" : ""}${e.value.toFixed(2)}`;
+    html += `<br><span style="color:#5adc5a">${esc(e.desc)}</span>`;
+    if (e.probs && actions.length) {
+      html += '<div style="margin-top:8px;color:#787e8c;font-size:12px">action probs</div>';
+      for (let i = 0; i < actions.length; i++) {
+        const hi = actions[i] === e.action;
+        const p = e.probs[i] ?? 0;
+        const pct = Math.round(p * 100);
+        const col = hi ? "#5adc5a" : p > 0.01 ? "#d2d6e0" : "#787e8c";
+        html +=
+          '<div style="display:flex;align-items:center;gap:6px;margin:3px 0">' +
+          `<span style="width:120px;color:${col};overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:12px">${esc(actions[i].slice(0, 16))}</span>` +
+          '<span style="flex:1;height:10px;background:#282c3a;border-radius:3px;overflow:hidden">' +
+          `<span style="display:block;height:10px;border-radius:3px;width:${pct}%;background:${hi ? "#5adc5a" : "#466ebe"}"></span></span>` +
+          `<span style="width:36px;text-align:right;color:${col};font-size:12px">${pct}%</span></div>`;
+      }
+    }
+    if (recent.length) {
+      html +=
+        '<div style="color:#787e8c;margin-top:8px;font-size:12px">recent:<br>' +
+        recent.map(esc).join("<br>") +
+        "</div>";
+    }
+    el.innerHTML = html;
+  }, 100);
+}
