diff --git a/src/client/RlDebugOverlay.ts b/src/client/RlDebugOverlay.ts
new file mode 100644
index 000000000..010ea13b2
--- /dev/null
+++ b/src/client/RlDebugOverlay.ts
@@ -0,0 +1,149 @@
+/**
+ * RL replay tooling: live model-debug panel.
+ *
+ * Fetches per-decision policy debug data (chosen action, action
+ * probabilities, value estimate) for the current game and renders a small
+ * fixed panel that follows the sim via window.__replayTick (set in
+ * ClientGameRunner).
+ *
+ * Sources tried in order, first 200 wins:
+ *   - localStorage "rlDebugHost"    (override for a non-default live port)
+ *   - localStorage "apiHost"        (replay shim, scripts/serve_replay.py)
+ *   - http://localhost:8988         (rl.play --debug-port default; only
+ *     probed when the client itself runs on localhost)
+ * at `${host}/debug/${gameID}`. Payload: { actions: string[], log: [...],
+ * live?: boolean }. When live, the log is re-fetched every 2s.
+ *
+ * Disable with localStorage "rlDebugOverlay" = "0".
+ */
+
+interface RlDebugEntry {
+  tick: number;
+  desc: string;
+  action: string;
+  tiles: number;
+  troops: number;
+  value?: number;
+  probs?: number[];
+}
+
+interface RlDebugPayload {
+  actions: string[];
+  log: RlDebugEntry[];
+  live?: boolean;
+}
+
+let initialized = false;
+
+function esc(s: string): string {
+  return s.replace(/&/g, "&amp;").replace(/</g, "&lt;");
+}
+
+export function initRlDebugOverlay(gameID: string): void {
+  if (initialized) return;
+  initialized = true;
+
+  let hosts: string[];
+  try {
+    if (localStorage.getItem("rlDebugOverlay") === "0") return;
+    const local = ["localhost", "127.0.0.1"].includes(
+      window.location.hostname,
+    );
+    hosts = [
+      localStorage.getItem("rlDebugHost"),
+      localStorage.getItem("apiHost"),
+      local ? "http://localhost:8988" : null,
+    ].filter((h): h is string => !!h);
+  } catch {
+    return;
+  }
+  if (hosts.length === 0) return;
+
+  void (async () => {
+    // A few attempts so a feed that comes up slightly after the first
+    // tick (or a slow shim) still gets the overlay.
+    for (let attempt = 0; attempt < 3; attempt++) {
+      for (const host of hosts) {
+        let data: RlDebugPayload;
+        try {
+          const resp = await fetch(`${host}/debug/${gameID}`);
+          if (!resp.ok) continue;
+          data = (await resp.json()) as RlDebugPayload;
+        } catch {
+          continue;
+        }
+        run(data, `${host}/debug/${gameID}`);
+        return;
+      }
+      await new Promise((r) => setTimeout(r, 5000));
+    }
+  })();
+}
+
+function run(data: RlDebugPayload, url: string): void {
+  const el = document.createElement("div");
+  el.style.cssText =
+    "position:fixed;left:8px;top:160px;width:250px;z-index:10005;" +
+    "background:rgba(12,14,22,.88);color:#d2d6e0;" +
+    "font:11px/1.4 ui-monospace,monospace;" +
+    "padding:8px 10px;border-radius:8px;pointer-events:none";
+  document.body.appendChild(el);
+
+  let log = data.log;
+  let idx = 0;
+  const recent: string[] = [];
+
+  if (data.live) {
+    setInterval(() => {
+      void fetch(url)
+        .then((r) => (r.ok ? r.json() : null))
+        .then((d: RlDebugPayload | null) => {
+          if (d) log = d.log;
+        })
+        .catch(() => {});
+    }, 2000);
+  }
+
+  setInterval(() => {
+    const t = (window as { __replayTick?: number }).__replayTick;
+    if (t === undefined) return;
+    while (idx < log.length && log[idx].tick <= t) {
+      const e = log[idx++];
+      if (e.action !== "noop") {
+        recent.push(`t${e.tick} ${e.desc}`);
+        if (recent.length > 8) recent.shift();
+      }
+    }
+    const e = idx > 0 ? log[idx - 1] : null;
+    let html =
+      '<b style="color:#fff">MODEL</b> ' +
+      `<span style="color:#787e8c">tick ${t}</span><br>`;
+    if (!e) {
+      el.innerHTML = html + "waiting for decisions...";
+      return;
+    }
+    html += `tiles ${e.tiles.toLocaleString()}  troops ${e.troops.toLocaleString()}`;
+    if (e.value !== undefined) html += `  v ${e.value.toFixed(2)}`;
+    html += `<br><span style="color:#5adc5a">${esc(e.desc)}</span>`;
+    if (e.probs) {
+      for (let i = 0; i < data.actions.length; i++) {
+        const hi = data.actions[i] === e.action;
+        const col = hi ? "#5adc5a" : e.probs[i] > 0.01 ? "#d2d6e0" : "#787e8c";
+        html +=
+          '<div style="display:flex;align-items:center;margin:1px 0">' +
+          `<span style="width:90px;color:${col}">${esc(data.actions[i].slice(0, 13))}</span>` +
+          '<span style="flex:1;height:7px;background:#282c3a;border-radius:2px">' +
+          `<span style="display:block;height:7px;border-radius:2px;width:${Math.round(
+            e.probs[i] * 100,
+          )}%;background:${hi ? "#5adc5a" : "#466ebe"}"></span></span></div>`;
+      }
+    }
+    if (recent.length) {
+      html +=
+        '<div style="color:#787e8c;margin-top:4px">recent:<br>' +
+        recent.map(esc).join("<br>") +
+        "</div>";
+    }
+    el.innerHTML = html;
+  }, 100);
+}
