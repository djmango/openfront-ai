# Optional operator overrides sourced by RunPod dockerArgs / pod shim.
# Copy to /root/ppo_v10.env on the pod. Unset keys fall back to
# scripts/pod_train_v10.sh defaults. Curriculum (stages/density/gates) is
# NOT configurable here — edit rust/ofcore/src/curriculum.rs.

# HF_TOKEN=hf_...          # required for ofhf sync-loop
SKIP_SYNC=1                # keep local patches / avoid reset --hard master
NODE_FRACTION=0
ALLOW_NODE_MIX=0
NUM_GPUS=4
NUM_ENVS=14
MIN_ENVS=8
MAX_ENVS=14                # A40 VRAM ceiling; curriculum floors of 24 clamp here
AUTO_SCALE_ENVS=1
TARGET_GPU_UTIL=0.85
NCCL_P2P_DISABLE=1
NCCL_IB_DISABLE=1
# RUN_NAME=ppo_v10
# HF_REPO_ID=djmango/openfront-rl
# HF_RUN_PREFIX=ppo_v10
